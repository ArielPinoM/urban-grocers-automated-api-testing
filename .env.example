# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env (optional) and fill values as needed.
# NOTE: Do NOT store the dynamic `BASE_URL` here because it expires. Pass it when running pytest.
# ============================================

# Base API URL (required, but provided at runtime)
# Do not hardcode here - pass it when running pytest.
# Example: BASE_URL=https://server-1234.tripleten.com pytest tests/

# Global HTTP request timeout (seconds)
TIMEOUT=10

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Current environment (only used for identification in logs/reports)
ENVIRONMENT=tripleten