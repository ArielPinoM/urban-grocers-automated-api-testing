# ============================================
# PLANTILLA DE VARIABLES DE ENTORNO
# ============================================
# Copia este archivo a .env (opcional) y completa los valores.
# NOTA: BASE_URL NO debe ir en .env porque caduca. Pásala al ejecutar pytest.
# ============================================

# URL base de la API (obligatoria, pero se pasa por línea de comandos)
# No la pongas aquí - se pasa al ejecutar pytest:
# Ejemplo: BASE_URL=https://server-1234.tripleten.com pytest tests/

# Timeout global para peticiones HTTP (segundos)
TIMEOUT=10

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Entorno actual (solo para identificación en logs/reportes)
ENVIRONMENT=tripleten